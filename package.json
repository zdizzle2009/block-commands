{
	"name": "block-commands",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"astro": "astro",
		"build": "astro check && astro build",
		"check": "astro check && pnpm run check:format && pnpm run check:lint && pnpm run check:types",
		"check:format": "oxfmt . --check",
		"check:lint": "oxlint src --max-warnings 0 --report-unused-disable-directives",
		"check:types": "tsc --noEmit",
		"dev": "astro dev",
		"fix": "pnpm fix:lint && pnpm fix:format",
		"fix:format": "oxfmt .",
		"fix:lint": "oxlint src --max-warnings 0 --report-unused-disable-directives --fix",
		"start": "npx serve ./dist"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.6",
		"@astrojs/markdoc": "^0.15.10",
		"@astrojs/netlify": "^6.6.4",
		"@astrojs/react": "^4.4.2",
		"@astrojs/rss": "^4.0.15",
		"@astrojs/sitemap": "^3.7.0",
		"@astrojs/tailwind": "^6.0.2",
		"@fontsource/press-start-2p": "^5.2.7",
		"@keystatic/astro": "^5.0.6",
		"@keystatic/core": "^0.5.48",
		"astro": "^5.18.0",
		"date-fns": "^4.1.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwindcss": "^4.2.1",
		"tiny-invariant": "^1.3.3"
	},
	"devDependencies": {
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"globals": "^17.4.0",
		"oxfmt": "^0.36.0",
		"oxlint": "^1.51.0",
		"react-compiler-runtime": "19.0.0-beta-ebf51a3-20250411",
		"typescript": "^5.9.3"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@10.31.0+sha512.e3927388bfaa8078ceb79b748ffc1e8274e84d75163e67bc22e06c0d3aed43dd153151cbf11d7f8301ff4acb98c68bdc5cadf6989532801ffafe3b3e4a63c268"
}
