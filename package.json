{
	"name": "block-commands",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"astro": "astro",
		"build": "astro check && astro build",
		"check": "astro check && pnpm run check:format && pnpm run check:lint && pnpm run check:types",
		"check:format": "oxfmt . --check",
		"check:lint": "oxlint src --max-warnings 0 --report-unused-disable-directives",
		"check:types": "tsc --noEmit",
		"dev": "astro dev",
		"fix": "pnpm fix:lint && pnpm fix:format",
		"fix:format": "oxfmt .",
		"fix:lint": "oxlint src --max-warnings 0 --report-unused-disable-directives --fix",
		"start": "npx serve ./dist"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.4",
		"@astrojs/markdoc": "^0.12.11",
		"@astrojs/netlify": "^6.5.10",
		"@astrojs/react": "^4.3.1",
		"@astrojs/rss": "^4.0.12",
		"@astrojs/sitemap": "^3.6.0",
		"@astrojs/tailwind": "^6.0.2",
		"@fontsource/press-start-2p": "^5.2.7",
		"@keystatic/astro": "^5.0.6",
		"@keystatic/core": "^0.5.48",
		"astro": "^5.13.8",
		"date-fns": "^4.1.0",
		"react": "^19.1.1",
		"react-dom": "^19.1.1",
		"tailwindcss": "^4.1.13",
		"tiny-invariant": "^1.3.3"
	},
	"devDependencies": {
		"@tailwindcss/typography": "^0.5.16",
		"@tailwindcss/vite": "^4.1.13",
		"@types/react": "^19.1.13",
		"@types/react-dom": "^19.1.9",
		"globals": "^17.0.0",
		"oxfmt": "^0.36.0",
		"oxlint": "^1.51.0",
		"react-compiler-runtime": "19.0.0-beta-ebf51a3-20250411",
		"typescript": "^5.9.2"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@10.17.0+sha512.fce8a3dd29a4ed2ec566fb53efbb04d8c44a0f05bc6f24a73046910fb9c3ce7afa35a0980500668fa3573345bd644644fa98338fa168235c80f4aa17aa17fbef"
}
