{
  "name": "block-commands",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "astro": "astro",
    "build": "astro check && astro build",
    "check": "astro check && pnpm run check:format && pnpm run check:lint && pnpm run check:types",
    "check:format": "prettier 'src/**/*.astro' --cache --check && oxfmt . --check",
    "check:lint": "oxlint src --max-warnings 0 --report-unused-disable-directives",
    "check:types": "tsc --noEmit",
    "dev": "astro dev",
    "fix": "pnpm fix:lint && pnpm fix:format",
    "fix:format": "prettier 'src/**/*.astro' --cache --write && oxfmt .",
    "fix:lint": "oxlint src --max-warnings 0 --report-unused-disable-directives --fix",
    "start": "npx serve ./dist"
  },
  "dependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/markdoc": "^1.0.6",
    "@astrojs/netlify": "^7.0.12",
    "@astrojs/react": "^5.0.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/tailwind": "^6.0.2",
    "@keystatic/astro": "^5.1.0",
    "@keystatic/core": "^0.5.50",
    "astro": "^6.4.5",
    "date-fns": "^4.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.0",
    "tiny-invariant": "^1.3.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react-compiler-runtime": "19.0.0-beta-ebf51a3-20250411",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
