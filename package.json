{
	"name": "block-commands",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"astro": "astro",
		"build": "astro check && astro build",
		"check": "astro check && pnpm run check:format && pnpm run check:lint && pnpm run check:types",
		"check:format": "oxfmt . --check",
		"check:lint": "oxlint src --max-warnings 0 --report-unused-disable-directives",
		"check:types": "tsc --noEmit",
		"dev": "astro dev",
		"fix": "pnpm fix:lint && pnpm fix:format",
		"fix:format": "oxfmt .",
		"fix:lint": "oxlint src --max-warnings 0 --report-unused-disable-directives --fix",
		"start": "npx serve ./dist"
	},
	"dependencies": {
		"@astrojs/check": "0.9.8",
		"@astrojs/markdoc": "^1.0.3",
		"@astrojs/netlify": "^7.0.6",
		"@astrojs/react": "^5.0.2",
		"@astrojs/rss": "^4.0.18",
		"@astrojs/sitemap": "^3.7.2",
		"@astrojs/tailwind": "^6.0.2",
		"@keystatic/astro": "^5.0.6",
		"@keystatic/core": "^0.5.50",
		"astro": "^6.1.3",
		"date-fns": "^4.1.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwindcss": "^4.2.2",
		"tiny-invariant": "^1.3.3"
	},
	"devDependencies": {
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"globals": "^17.4.0",
		"oxfmt": "^0.43.0",
		"oxlint": "^1.58.0",
		"react-compiler-runtime": "19.0.0-beta-ebf51a3-20250411",
		"typescript": "^6.0.2"
	},
	"engines": {
		"node": ">=22.12.0"
	},
	"packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
